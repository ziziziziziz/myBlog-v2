---
// 导航链接配置
const navLinks = [
  { name: '首页', href: '/' },
  { name: '关于', href: '/about' },
  { name: '文柜', href: '/publication' },
];
---

<header class="navbar">
  <div class="navbar-container">
    <a href="/" class="logo">qlz</a>
    <nav>
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-link">{link.name}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .navbar {
    border-bottom: 1px solid #eaeaea;
    background-color: white;
    position: fixed;
    width: 100%;
    height: 70px;
  }

  .navbar-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--theme-color);
  }

  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: #4a5568;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--theme-color);
  }
</style>