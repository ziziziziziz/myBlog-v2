---
import Layout from '../layouts/Layout.astro';

export interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<Layout title={title}>
  <article>
    <h1>{title}</h1>
    <time>
      {new Date(date).toLocaleDateString('zh-CN')}
    </time>
    <div class="content">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .content :is(h2, h3) {
    margin: 1.5rem 0 0.5rem;
  }
  .content p {
    margin-bottom: 1rem;
  }
  .content pre {
    background: #f4f4f4;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
</style>